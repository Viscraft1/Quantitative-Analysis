APP_NAME=Quant Platform API
APP_ENV=local
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./quant.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
CREATE_TABLES_ON_STARTUP=true
SQL_ECHO=false
DEFAULT_RANKING_LIMIT=20
# auto = 通达信本地历史数据优先，拿不到时回退 AkShare
MARKET_DATA_PROVIDER=auto
TUSHARE_TOKEN=
TDX_ROOT=E:/Tongdaxin/vipdoc
FETCH_LOOKBACK_DAYS=30
FETCH_SYMBOL_LIMIT=0
FETCH_BATCH_SLEEP_SECONDS=0
FACTOR_LOOKBACK_DAYS=120
SCREENING_TOP_N=20
SCREEN_MIN_LISTING_DAYS=120
SCREEN_MIN_TURNOVER_RATE=1
SCREEN_MIN_TOTAL_MV_YI=20
SCREEN_TECH_WEIGHT=0.40
SCREEN_FUND_WEIGHT=0.35
SCREEN_FLOW_WEIGHT=0.15
SCREEN_SENTIMENT_WEIGHT=0.10
SCREEN_STRATEGY_VERSION=oversold_v1.1.0

# Realtime quotes (AkShare / Tencent / Sina)
REALTIME_QUOTE_SOURCES=tencent,sina,akshare
REALTIME_REQUEST_TIMEOUT_SECONDS=8
REALTIME_QUOTE_BATCH_SIZE=180
# Use HTTP_PROXY/HTTPS_PROXY/NO_PROXY, and on Windows the app also reuses enabled system proxy settings.
REALTIME_TRUST_ENV=true
# Optional explicit proxy. Leave blank unless you know your local proxy address.
REALTIME_PROXY=

POSTGRES_DB=quant_platform
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant

VITE_API_BASE_URL=/api/v1
